# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (optional — app falls back to mock checkout if missing)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend transactional email (optional — app no-ops if missing)
RESEND_API_KEY=
RESEND_FROM_EMAIL="BagSlot <notifications@bagslot.app>"

# Google Maps Places autocomplete + map preview (optional — falls back to plain text input)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin bootstrap (comma-separated emails get is_admin=true on first signup)
ADMIN_EMAILS=
